---
import Icon from "@src/components/Icons.astro";

const {
	title,
	description,
	tags = [],
	icons = [],
	actioncomponent,
} = Astro.props;
---

<div
	class="border-primary/5 group flex w-full min-w-0 flex-col justify-between rounded-3xl border bg-white/40 p-8 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-2 hover:shadow-xl dark:bg-black/20"
>
	<div class="min-w-0">
		<div class="mb-6 flex items-start justify-between">
			<div class="flex gap-2">
				{
					icons.map((i: string) => (
						<Icon
							name={i}
							class="text-primary/80 group-hover:text-accent h-8 w-8 transition-colors"
						/>
					))
				}
			</div>
		</div>

		<h3
			class="text-primary mb-3 truncate text-[clamp(1.5rem,5vw,1.875rem)] font-bold"
			title={title}
		>
			{title}
		</h3>
		<p
			class="mb-4 text-[clamp(1rem,2.5vw,1.125rem)] leading-relaxed opacity-80"
		>
			{description}
		</p>

		<div class="flex flex-wrap gap-2">
			{
				tags.map((tag: string) => (
					<span class="bg-accent/10 text-accent border-accent/20 rounded-full border px-2 py-0.5 text-[10px] font-bold tracking-wider uppercase">
						{tag}
					</span>
				))
			}
		</div>
	</div>

	<div class="border-primary/5 mt-8 flex justify-end border-t pt-6">
		{
			actioncomponent
				? ((ActionComponent) => (
						<ActionComponent {...actioncomponent[1]} />
					))(actioncomponent[0])
				: null
		}
	</div>
</div>
