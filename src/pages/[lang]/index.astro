---
import BaseLayout from "@src/layouts/BaseLayout.astro";
import Icon from "@src/components/Icons.astro";
import Projects from "@src/components/Projects.astro";
import { useTranslations } from "@src/lib/i18n";
import { Lang, LOCALES } from "@src/lib/locales";
import { LINKEDIN_PROFILE_URL } from "@src/lib/consts";

const locale = Astro.currentLocale as Lang;
const { t } = useTranslations(locale);

export const getStaticPaths = () =>
	Object.keys(LOCALES).map((lang) => ({
		params: { lang },
	}));
---

<BaseLayout class="bg-element overflow-x-hidden">
	<section
		class="animate-fade-in relative my-16 flex min-h-[70vh] flex-col justify-center p-[clamp(--spacing(4),4vw,--spacing(32))]"
	>
		<!-- Background Impression -->
		<div
			class="text-primary/10 md:text-primary/20 absolute top-1/2 right-0 -z-10 h-[90%] w-auto -translate-y-1/2 transition-colors"
		>
			<span class="flex h-full w-auto">
				<Icon
					name="jasper-impression"
					class="h-full w-auto object-contain"
				/>
			</span>
		</div>

		<div class="relative z-10 w-full flex-col justify-between">
			<span
				class="animate-slide-up flex flex-wrap-reverse items-center justify-between 2xl:justify-start"
			>
				<h1
					class="text-primary flex text-[clamp(2.5rem,10vw,8rem)] leading-tight font-bold tracking-tight"
				>
					Jasper Albering
				</h1>

				<Icon
					name="logo"
					class="text-primary flex h-[clamp(6rem,20vw,8rem)] w-[clamp(6rem,20vw,8rem)] transition-transform hover:rotate-6 2xl:ml-8"
					aria-label="Jasper Albering Logo"
				/>
			</span>
			<span
				class="animate-slide-up my-12 block max-w-4xl space-y-6 text-lg leading-relaxed md:text-xl"
			>
				{
					t({
						en: (
							<>
								<p class="text-accent text-sm font-bold tracking-widest uppercase opacity-90">
									Introduction
								</p>
								<p>Hello, I'm Jasper.</p>
								<p>
									I like to work with all kinds of technology;
									tinkering with Linux, domotics, networking and a bit
									of electronics.
								</p>
								<p>
									After graduating from my BSc. Computer Science at
									Utrecht University in May 2025, I have been taking a
									break, and am currently looking for a position as a
									DevOps/Cloud Engineer, Systems Engineer, Full-stack
									developer or similar (32-40 hours).
								</p>
								<p>Contact me on LinkedIn.</p>
							</>
						),
						nl: (
							<>
								<p class="text-accent text-sm font-bold tracking-widest uppercase opacity-90">
									Introductie
								</p>
								<p>Hoi, ik ben Jasper</p>
								<p>
									Ik ben graag bezig met allerlei soorten technologie.
									Denk dan vooral aan Linux, domotica, netwerken en een
									beetje elektronica.
								</p>
								<p>
									Na mijn afstuderen als BSc. Informatica/Computer
									Science aan de Universiteit Utrecht in mei 2025, heb
									ik een pauze genomen, en ik zoek momenteel naar een
									functie als DevOps/Cloud Engineer, Systems Engineer,
									Full-stack developer of vergelijkbaar (32-40 uur).
								</p>
								<p>Neem contact met me op via LinkedIn.</p>
							</>
						),
					})
				}
			</span>

			<div
				class="animate-slide-up mt-8 flex w-max max-w-full flex-wrap gap-4"
			>
				<a
					href={LINKEDIN_PROFILE_URL}
					class="bg-accent flex w-full items-center justify-center rounded-full px-8 py-4 text-sm font-bold text-white shadow-lg transition-all hover:-translate-y-1 hover:shadow-xl sm:w-max dark:text-gray-900"
					>{t({ en: "View my resume", nl: "Bekijk mijn cv" })}&nbsp;<Icon
						name="linkedin"
						class="h-4 w-4"
					/>
				</a>
				<a
					href={LINKEDIN_PROFILE_URL}
					class="border-primary text-primary hover:bg-primary flex w-full items-center justify-center rounded-full border-2 bg-transparent px-8 py-4 text-sm font-bold transition-all hover:-translate-y-1 hover:text-white hover:shadow-xl sm:w-max"
					>{t({ en: "Contact me", nl: "Neem contact op" })}&nbsp;<Icon
						name="linkedin"
						class="h-4 w-4"
					/>
				</a>
				<a
					href="https://github.com/jasperro"
					class="flex w-max items-center rounded-full bg-gray-900 px-4 py-4 text-white shadow-lg transition-all hover:-translate-y-1 hover:shadow-xl dark:bg-gray-800"
					aria-label="GitHub Profile"
				>
					<Icon name="github" class="h-6 w-6" />
				</a>
			</div>
		</div>
	</section>

	<section
		class="animate-slide-up px-[clamp(--spacing(4),4vw,--spacing(32))] pb-24"
	>
		<h2
			class="text-accent mb-12 text-sm font-bold tracking-widest uppercase opacity-80"
		>
			{t({ en: "Expertise", nl: "Expertise" })}
		</h2>
		<div class="flex flex-wrap gap-4 md:gap-6">
			{
				[
					{
						name: "Linux",
						color: "bg-zinc-100 text-zinc-800 dark:bg-zinc-800/50 dark:text-zinc-200",
					},
					{
						name: "Full-Stack Development",
						color: "bg-primary/10 text-primary dark:bg-primary/20 dark:text-blue-300",
					},
					{
						name: "Home Automation",
						color: "bg-violet-100 text-violet-800 dark:bg-violet-900/40 dark:text-violet-200",
					},
					{
						name: "Open Source",
						color: "bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent",
					},
					{
						name: "Electronics",
						color: "bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-200",
					},
				].map((skill) => (
					<div
						class={`cursor-default rounded-2xl border border-black/5 px-8 py-4 text-lg font-semibold transition-all duration-300 hover:scale-105 hover:shadow-lg md:text-xl dark:border-white/5 ${skill.color}`}
					>
						{skill.name}
					</div>
				))
			}
		</div>
	</section>

	<Projects locale={locale} />
</BaseLayout>
